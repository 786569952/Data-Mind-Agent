# 阿里百炼 DashScope API Key
# 获取地址: https://bailian.console.aliyun.com/  ->  API-KEY 管理
DASHSCOPE_API_KEY=sk-your-bailian-api-key-here

# 默认使用的模型 (可在前端界面覆盖配置)
# 可选: qwen-turbo / qwen-plus / qwen-max / qwen-long
DEFAULT_CHAT_MODEL=qwen-plus
# 可选: text-embedding-v1 / text-embedding-v2 / text-embedding-v3
DEFAULT_EMBEDDING_MODEL=text-embedding-v3
